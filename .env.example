# Copy this file to .env and fill in real values. NEVER commit the real .env.

# Your Microsoft Clarity Data Export API token.
# Get it from: Clarity project -> Settings -> Data Export -> Generate new API token
CLARITY_API_TOKEN=paste_your_clarity_token_here

# The token YOUR MANAGER will use to connect to your MCP server.
# This is NOT a Clarity token -- it's one you invent yourself.
# Generate a strong random one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_ACCESS_TOKEN=paste_a_long_random_string_here

# How long (in seconds) cached Clarity responses stay valid before a
# repeat question triggers a fresh API call. 3600 = 1 hour.
CACHE_TTL_SECONDS=3600

# Local port the server listens on. Your tunnel (ngrok/Cloudflare) points here.
PORT=8000
